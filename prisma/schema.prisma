generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// BRANCHES
// ─────────────────────────────────────────────
model Branch {
  id        String   @id @default(cuid())
  name      String   @unique
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  members     Member[]
  employees   Employee[]
  remittances Remittance[]
  cutoffs     OperationCutoff[]
}

// ─────────────────────────────────────────────
// USERS (System Login Accounts)
// ─────────────────────────────────────────────
model User {
  id          String   @id @default(cuid())
  username    String   @unique
  password    String
  role        UserRole @default(BRANCH_STAFF)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  isActive    Boolean  @default(true)
  displayName String?
  email       String?
  phone       String?
  avatar      String?  @db.Text // base64 profile picture
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum UserRole {
  ADMIN
  BRANCH_STAFF
  HR
}

// ─────────────────────────────────────────────
// EMPLOYEES
// ─────────────────────────────────────────────
model Employee {
  id            String    @id @default(cuid())
  employeeNo    String    @unique
  // Primary/display position (highest rank)
  primaryPosition EmployeePosition
  firstName     String
  middleName    String?
  lastName      String
  nickname      String?
  dateOfBirth   DateTime?
  gender        Gender?
  civilStatus   String?
  contactNumber String?
  address       String?
  email         String?
  photo         String?   @db.Text // base64 profile picture
  dateHired     DateTime  @default(now())
  isActive      Boolean   @default(true)
  branchId      String
  branch        Branch    @relation(fields: [branchId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Collector balance: negative = deficit (owes), positive = surplus
  // Surplus resets to 0 at month-end; deficit carries forward
  collectorBalance Decimal @db.Decimal(10, 2) @default(0)

  // Sponsor = who recruited this person (upline for commission cascade)
  sponsorId     String?
  sponsor       Employee? @relation("EmployeeSponsor", fields: [sponsorId], references: [id])
  recruits      Employee[] @relation("EmployeeSponsor")

  // Multiple positions per employee (MO can also be MH and AM simultaneously)
  positions     EmployeePositionRecord[]

  // Links to member transactions
  agentMembers     Member[]     @relation("MemberAgent")
  collectorMembers Member[]     @relation("MemberCollector")
  payments         Payment[]
  commissions      Commission[]
  remittances      Remittance[]

  // Payroll
  salaryProfile    SalaryProfile?
  payslips         Payslip[]
  loans            Loan[]
  thirteenthMonth  ThirteenthMonth[]

  @@index([primaryPosition])
  @@index([branchId])
  @@index([sponsorId])
}

// Tracks each position a person holds (can have MO + MH + AM simultaneously)
model EmployeePositionRecord {
  id           String           @id @default(cuid())
  employeeId   String
  employee     Employee         @relation(fields: [employeeId], references: [id])
  position     EmployeePosition
  dateGranted  DateTime         @default(now())
  isActive     Boolean          @default(true)
  notes        String?
  createdAt    DateTime         @default(now())

  @@unique([employeeId, position])
  @@index([employeeId])
}

// Promotion history log
model PromotionHistory {
  id           String           @id @default(cuid())
  employeeId   String
  fromPosition EmployeePosition?
  toPosition   EmployeePosition
  promotedDate DateTime         @default(now())
  notes        String?
  createdAt    DateTime         @default(now())

  @@index([employeeId])
}

enum EmployeePosition {
  MO   // Marketing Officer / Sales Agent
  AO   // Account Officer / Collector
  MH   // Marketing Head
  AM   // Area Manager
  CS   // Collection Supervisor
  BS   // Branch Staff
  BM   // Branch Manager
  RM   // Regional Manager
  TH   // Territory Head
  EVP  // Executive Vice President
  CEO  // Chief Executive Officer
  CHR  // Chairman
}

// ─────────────────────────────────────────────
// MEMBERS
// ─────────────────────────────────────────────
model Member {
  id              String        @id @default(cuid())
  mafNo           String        @unique
  enrollmentDate  DateTime
  insuranceType   InsuranceType
  planCategory    PlanCategory
  mopCode         MopCode
  firstName       String
  middleName      String?
  lastName        String
  address         String
  dateOfBirth     DateTime?
  age             Int?
  religion        String?
  contactNumber   String?
  occupation      String?
  civilStatus     String?
  gender          Gender?

  // Pricing
  monthlyDue      Decimal       @db.Decimal(10, 2)
  totalPlanAmount Decimal       @db.Decimal(10, 2)
  spotCash        Boolean       @default(false)
  spotCashAmount  Decimal?      @db.Decimal(10, 2)

  // Status
  status          MemberStatus  @default(ACTIVE)
  lapseDate       DateTime?
  reinstatedDate  DateTime?
  reinstateType   ReinstateType?
  effectivityDate DateTime?
  fullyPaidDate   DateTime?
  deceasedDate    DateTime?

  // Operation tag (month/year when enrolled e.g. "January 2026")
  operationMonth  Int?
  operationYear   Int?

  // Relationships
  branchId        String
  branch          Branch        @relation(fields: [branchId], references: [id])
  agentId         String?
  agent           Employee?     @relation("MemberAgent", fields: [agentId], references: [id])
  collectorId     String?
  collector       Employee?     @relation("MemberCollector", fields: [collectorId], references: [id])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  beneficiaries   Beneficiary[]
  payments        Payment[]
  commissions     Commission[]
  editRequests    MemberEditRequest[]
  claims          Claim[]

  @@index([mafNo])
  @@index([status])
  @@index([branchId])
  @@index([collectorId])
  @@index([agentId])
  @@index([operationYear, operationMonth])
}

enum InsuranceType {
  FAMILY_INSURANCE
  NON_INSURABLE
  INDIVIDUAL_INSURANCE
}

enum PlanCategory {
  EUCALYPTUS
  CHERRY
  CONIFER
  ROSEWOOD
}

// MOP Codes — Insurance Type + Mode + Plan (suffix 2 = 2025 new price)
enum MopCode {
  // Family Insurance + Eucalyptus (old P420)
  FIME
  FIQE
  FISAE
  FIAE
  // Family Insurance + Eucalyptus (new P450 from 2025)
  FIME2
  FIQE2
  FISAE2
  FIAE2
  // Non Insurable + Cherry (old P340)
  NIMC
  NIQC
  NISAC
  NIAC
  // Non Insurable + Cherry (new P380 from 2025)
  NIMC2
  NIQC2
  NISAC2
  NIAC2
  // Family Insurance + Conifer (P650, discontinued)
  FIMC
  FIQC
  FISAC
  FIAC
  // Individual Insurance + Rosewood (P1250, discontinued)
  IIMR
  IIQR
  IISAR
  IIAR
  // Spot Cash
  SPOT_CASH
}

enum MemberStatus {
  ACTIVE
  LAPSED
  REINSTATED
  FULLY_PAID
  DECEASED_CLAIMANT
  CANCELLED
}

enum ReinstateType {
  REDATE
  UPDATE
}

enum Gender {
  MALE
  FEMALE
}

// ─────────────────────────────────────────────
// BENEFICIARIES
// ─────────────────────────────────────────────
model Beneficiary {
  id              String   @id @default(cuid())
  memberId        String
  member          Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  order           Int
  firstName       String
  middleName      String?
  lastName        String
  dateOfBirth     DateTime?
  age             Int?
  relationship    String
  effectivityDate DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─────────────────────────────────────────────
// CLAIMS
// ─────────────────────────────────────────────
model Claim {
  id                String      @id @default(cuid())
  claimNo           String      @unique
  memberId          String
  member            Member      @relation(fields: [memberId], references: [id])
  branchId          String

  // Deceased info
  deceasedType      DeceasedType // MEMBER or BENEFICIARY
  deceasedName      String       // Full name of deceased
  dateOfDeath       DateTime
  causeOfDeath      String?
  deathType         DeathType?   // NATURAL, ACCIDENT, SUICIDE
  isEligible        Boolean      @default(true)
  eligibilityNote   String?      // reason if not eligible

  // Spot service (non-members)
  isSpotService     Boolean      @default(false)
  spotServiceAmount Decimal?     @db.Decimal(12, 2) // default 30,000
  spotClientName    String?
  spotClientContact String?
  spotClientAddress String?

  // Claimant info (who receives the money)
  claimantName      String       // Full name of claimant/beneficiary
  claimantRelationship String    // Relationship to deceased
  claimantContact   String?
  claimantAddress   String?

  // Plan & amount
  planCategory      String       // plan at time of claim
  approvedAmount    Decimal?     @db.Decimal(12, 2) // editable, set when approved
  releasedAmount    Decimal?     @db.Decimal(12, 2) // actual amount released
  dateReleased      DateTime?

  // Workflow
  status            ClaimStatus  @default(STUB_ISSUED)
  filedDate         DateTime     @default(now())
  submittedToHO     DateTime?    // date docs submitted to head office
  verifiedDate      DateTime?
  approvedDate      DateTime?
  rejectedDate      DateTime?
  rejectionReason   String?
  processedBy       String?      // userId who processed
  approvedBy        String?      // userId who approved

  // Tracking
  courierTracking   String?        // courier tracking number
  additionalDocsNote String?       // what additional docs are needed

  // Documents
  documents         ClaimDocument[]
  statusLogs        ClaimStatusLog[]

  notes             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([memberId])
  @@index([branchId])
  @@index([status])
}

enum DeceasedType {
  MEMBER
  BENEFICIARY
  SPOT_SERVICE // Non-member, contract service
}

enum DeathType {
  NATURAL    // illness, assassination, provocation
  ACCIDENT   // accident, misfired/stray bullet
  SUICIDE    // self-inflicted
}

enum ClaimStatus {
  STUB_ISSUED              // Branch gave claim stub + requirements list
  DOCS_RECEIVED_BRANCH     // Claimant submitted documents to branch
  DOCS_IN_TRANSIT          // Original docs shipped via courier to HO
  DOCS_RECEIVED_HO         // Head office received the documents
  UNDER_REVIEW             // HO reviewing/verifying documents
  ADDITIONAL_DOCS_NEEDED   // Lacking documents, request more from claimant
  IN_PROGRESS              // All docs complete, processing claim
  APPROVED                 // Claim approved
  REJECTED                 // Claim denied (with reason)
  CHEQUE_PREPARING         // Finance preparing cheque
  CHEQUE_IN_TRANSIT        // Cheque shipped back to branch
  CHEQUE_RECEIVED_BRANCH   // Branch received the cheque
  RELEASED                 // Cheque released to claimant
}

model ClaimDocument {
  id          String   @id @default(cuid())
  claimId     String
  claim       Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  docType     String   // "DEATH_CERTIFICATE", "MARRIAGE_CERTIFICATE", "BIRTH_CERTIFICATE", etc.
  fileName    String
  fileData    String   @db.Text // base64 encoded
  uploadedBy  String?
  createdAt   DateTime @default(now())

  @@index([claimId])
}

model ClaimStatusLog {
  id          String      @id @default(cuid())
  claimId     String
  claim       Claim       @relation(fields: [claimId], references: [id], onDelete: Cascade)
  fromStatus  String?
  toStatus    String
  note        String?
  updatedBy   String?     // userId
  createdAt   DateTime    @default(now())

  @@index([claimId])
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────
model Payment {
  id               String        @id @default(cuid())
  memberId         String
  member           Member        @relation(fields: [memberId], references: [id])
  collectorId      String?
  collector        Employee?     @relation(fields: [collectorId], references: [id])
  remittanceId     String?
  remittance       Remittance?   @relation(fields: [remittanceId], references: [id])

  orNo             String?
  orDate           DateTime?
  installmentNo    Int
  periodMonth      Int
  periodYear       Int
  paymentDate      DateTime
  amount           Decimal       @db.Decimal(10, 2)
  othersDeduction  Decimal?      @db.Decimal(10, 2)
  isFree           Boolean       @default(false)
  isSpotCash       Boolean       @default(false)
  bcOutright       Boolean       @default(true)   // true = agent took BC during collection; false = BC included in deposit
  paymentMethod    PaymentMethod @default(CASH)
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([memberId])
  @@index([periodYear, periodMonth])
  @@index([remittanceId])
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  GCASH
  OTHER
}

// ─────────────────────────────────────────────
// REMITTANCES
// ─────────────────────────────────────────────
model Remittance {
  id                  String     @id @default(cuid())
  remittanceNo        String     @unique
  collectorId         String
  collector           Employee   @relation(fields: [collectorId], references: [id])
  branchId            String
  branch              Branch     @relation(fields: [branchId], references: [id])
  remittanceDate      DateTime
  periodMonth         Int
  periodYear          Int
  totalCollection     Decimal    @db.Decimal(10, 2)
  totalCommission     Decimal    @db.Decimal(10, 2)
  travellingAllowance Decimal    @db.Decimal(10, 2) @default(0)
  totalOthers         Decimal    @db.Decimal(10, 2) @default(0)
  netRemittance       Decimal    @db.Decimal(10, 2)
  totalDeposit        Decimal?   @db.Decimal(10, 2)
  receivedBy          String?
  collectionSupervisor String?
  branchManagerName   String?
  notes               String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  payments    Payment[]
  commissions Commission[]
}

// ─────────────────────────────────────────────
// PAYMENT EDIT REQUESTS (approval workflow)
// ─────────────────────────────────────────────
model PaymentEditRequest {
  id          String            @id @default(cuid())
  paymentId   String
  requestedBy String            // userId of branch staff
  status      EditRequestStatus @default(PENDING)
  changes     Json              // requested field changes
  reason      String?
  attachment  String?           @db.Text // base64 encoded image (receipt/evidence)
  reviewedBy  String?           // userId of approving admin
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([paymentId])
  @@index([status])
  @@index([requestedBy])
}

model MemberEditRequest {
  id          String            @id @default(cuid())
  memberId    String
  member      Member            @relation(fields: [memberId], references: [id])
  requestType String            @default("EDIT") // "EDIT" or "DELETE"
  requestedBy String            // userId of branch staff
  status      EditRequestStatus @default(PENDING)
  changes     Json?             // requested field changes (null for DELETE)
  reason      String?
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([memberId])
  @@index([status])
}

enum EditRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────
// COMMISSIONS
// ─────────────────────────────────────────────
model Commission {
  id             String     @id @default(cuid())
  employeeId     String
  employee       Employee   @relation(fields: [employeeId], references: [id])
  memberId       String
  member         Member     @relation(fields: [memberId], references: [id])
  remittanceId   String?
  remittance     Remittance? @relation(fields: [remittanceId], references: [id])

  installmentNo  Int
  paymentDate    DateTime
  grossAmount    Decimal    @db.Decimal(10, 2)
  commissionRate Decimal    @db.Decimal(5, 4)
  commissionAmt  Decimal    @db.Decimal(10, 2)
  isPaid         Boolean    @default(false)
  paidDate       DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([employeeId])
  @@index([memberId])
}

// ─────────────────────────────────────────────
// OPERATION CUTOFFS
// ─────────────────────────────────────────────
// Tracks the cutoff deadline for each month's operation.
// Default is last day of the month. Can be extended (e.g., holidays).
model OperationCutoff {
  id           String   @id @default(cuid())
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id])
  month        Int      // 1-12
  year         Int
  defaultDate  DateTime // Normal cutoff (last day of month)
  extendedDate DateTime // Extended cutoff (e.g., April 6 for March)
  reason       String?  // "Holy Week holidays"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([branchId, month, year])
}

// ─────────────────────────────────────────────
// PAYROLL — SALARY PROFILES
// ─────────────────────────────────────────────
model SalaryProfile {
  id              String   @id @default(cuid())
  employeeId      String   @unique
  employee        Employee @relation(fields: [employeeId], references: [id])
  basicSalary     Decimal  @db.Decimal(12, 2) // Monthly basic salary
  riceAllowance   Decimal  @db.Decimal(10, 2) @default(0)
  transpoAllowance Decimal @db.Decimal(10, 2) @default(0)
  otherAllowance  Decimal  @db.Decimal(10, 2) @default(0)
  paySchedule     PaySchedule @default(REGULAR) // REGULAR = 5th/20th, EXECUTIVE = 15th/end
  sssNo           String?
  philhealthNo    String?
  pagibigNo       String?
  tinNo           String?
  sssContribution   Decimal @db.Decimal(10, 2) @default(0)
  philhealthContribution Decimal @db.Decimal(10, 2) @default(0)
  pagibigContribution Decimal @db.Decimal(10, 2) @default(0)
  withholdingTax  Decimal  @db.Decimal(10, 2) @default(0)
  lateGraceMins   Int      @default(30)  // Grace period in minutes (no charge)
  lateRatePerHour Decimal  @db.Decimal(10, 2) @default(0) // Deduction per hour of late
  dailyRate       Decimal  @db.Decimal(10, 2) @default(0) // Deduction per day of absence (0 = auto from basic/22)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum PaySchedule {
  REGULAR    // 5th and 20th
  EXECUTIVE  // 15th and end of month
}

// ─────────────────────────────────────────────
// PAYROLL — PAYSLIPS
// ─────────────────────────────────────────────
model Payslip {
  id             String   @id @default(cuid())
  employeeId     String
  employee       Employee @relation(fields: [employeeId], references: [id])
  periodStart    DateTime // e.g. April 1
  periodEnd      DateTime // e.g. April 15
  payDate        DateTime // e.g. April 20
  cutoffLabel    String   // e.g. "April 1-15, 2026" or "April 16-30, 2026"

  // Earnings
  basicPay       Decimal  @db.Decimal(12, 2) // half of monthly basic
  overtime       Decimal  @db.Decimal(10, 2) @default(0)
  holidayPay     Decimal  @db.Decimal(10, 2) @default(0)
  allowances     Decimal  @db.Decimal(10, 2) @default(0) // rice + transpo + other
  otherEarnings  Decimal  @db.Decimal(10, 2) @default(0)
  grossPay       Decimal  @db.Decimal(12, 2)

  // Attendance
  daysWorked     Int      @default(0)
  daysAbsent     Decimal  @db.Decimal(5, 1) @default(0) // supports half days
  lateMins       Int      @default(0)  // total late minutes (after grace deducted)
  lateDeduction  Decimal  @db.Decimal(10, 2) @default(0)

  // Deductions
  sss            Decimal  @db.Decimal(10, 2) @default(0)
  philhealth     Decimal  @db.Decimal(10, 2) @default(0)
  pagibig        Decimal  @db.Decimal(10, 2) @default(0)
  tax            Decimal  @db.Decimal(10, 2) @default(0)
  cashAdvance    Decimal  @db.Decimal(10, 2) @default(0)
  absences       Decimal  @db.Decimal(10, 2) @default(0)
  otherDeductions Decimal @db.Decimal(10, 2) @default(0)
  totalDeductions Decimal @db.Decimal(12, 2)

  netPay         Decimal  @db.Decimal(12, 2)
  notes          String?
  status         PayslipStatus @default(DRAFT)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([employeeId])
  @@index([payDate])
  @@index([status])
}

enum PayslipStatus {
  DRAFT
  APPROVED
  RELEASED
}

// ─────────────────────────────────────────────
// PAYROLL — LOANS / CASH ADVANCES
// ─────────────────────────────────────────────
model Loan {
  id             String   @id @default(cuid())
  employeeId     String
  employee       Employee @relation(fields: [employeeId], references: [id])
  type           LoanType @default(CASH_ADVANCE)
  description    String?
  amount         Decimal  @db.Decimal(12, 2) // Total loan amount
  balance        Decimal  @db.Decimal(12, 2) // Remaining balance
  monthlyDeduction Decimal @db.Decimal(10, 2) @default(0) // Per-cutoff deduction
  startDate      DateTime
  status         LoanStatus @default(ACTIVE)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  payments       LoanPayment[]

  @@index([employeeId])
  @@index([status])
}

enum LoanType {
  CASH_ADVANCE
  SSS_LOAN
  PAGIBIG_LOAN
  SALARY_LOAN
  OTHER
}

enum LoanStatus {
  ACTIVE
  FULLY_PAID
  CANCELLED
}

model LoanPayment {
  id        String   @id @default(cuid())
  loanId    String
  loan      Loan     @relation(fields: [loanId], references: [id])
  amount    Decimal  @db.Decimal(10, 2)
  payDate   DateTime
  notes     String?
  createdAt DateTime @default(now())

  @@index([loanId])
}

// ─────────────────────────────────────────────
// PAYROLL — 13TH MONTH PAY
// ─────────────────────────────────────────────
model ThirteenthMonth {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  year         Int
  half         Int      // 1 = Jan-Jun (Q2 release), 2 = Jul-Dec (Q4 release)
  totalBasic   Decimal  @db.Decimal(12, 2) // Total basic earned in period
  amount       Decimal  @db.Decimal(12, 2) // 13th month amount = totalBasic / 12
  status       PayslipStatus @default(DRAFT)
  releasedDate DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([employeeId, year, half])
  @@index([employeeId])
}
